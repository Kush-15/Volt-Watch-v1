<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="false"
    android:background="@color/bg_dark">

    <TextView
        android:id="@+id/screenTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:text="Volt Watch"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/homeScreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include layout="@layout/fragment_home" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/historyScreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <include layout="@layout/fragment_history" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/reportScreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <include layout="@layout/fragment_report" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/commuteScreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <include layout="@layout/fragment_commute_check" />
        </FrameLayout>
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bg_dark"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/homeTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/homeTabIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_home_nav"
                android:tint="@color/accent_orange" />

            <TextView
                android:id="@+id/homeTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/accent_orange"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/historyTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/historyTabIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_history_nav"
                android:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/historyTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/reportTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/reportTabIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_report_nav"
                android:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/reportTabLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
