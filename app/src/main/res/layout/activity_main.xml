<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- ─── App Title ─── -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Battery Forecast"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- ─── Battery Icon + Percentage Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="32dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- Canvas battery icon -->
                <com.example.myapplication.BatteryIconView
                    android:id="@+id/batteryIcon"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_marginBottom="20dp" />

                <!-- Large % number -->
                <TextView
                    android:id="@+id/batteryPercentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—%"
                    android:textColor="@color/battery_green"
                    android:textSize="72sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="4dp" />

                <!-- Status label -->
                <TextView
                    android:id="@+id/batteryStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Initializing..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.04" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Time Remaining Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESTIMATED BATTERY LIFE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/timeRemainingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculating..."
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/todText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Graph Card ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BATTERY HISTORY"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/sampleCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <com.example.myapplication.BatteryGraphView
                    android:id="@+id/batteryGraph"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="8dp" />

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="4dp">

                    <View
                        android:layout_width="24dp"
                        android:layout_height="3dp"
                        android:background="@color/battery_green"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recorded"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginEnd="20dp" />

                    <View
                        android:layout_width="24dp"
                        android:layout_height="3dp"
                        android:background="@color/battery_amber"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Predicted"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
