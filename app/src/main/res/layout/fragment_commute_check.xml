<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/commuteBackText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Back"
            android:textColor="@color/nav_check_text"
            android:textSize="13sp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Commute check"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="Will your battery last the trip?"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="HOW LONG IS YOUR TRIP?"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/commuteSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="120"
                android:progress="45"
                android:progressTint="@color/accent_orange"
                android:thumbTint="@color/accent_orange" />

            <TextView
                android:id="@+id/commuteDurationText"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="45 min"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@color/card_bg"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Battery now" android:textColor="@color/text_muted" android:textSize="10sp" />
                <TextView
                    android:id="@+id/commuteBatteryNowValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XX%"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@color/card_bg"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Est. time left" android:textColor="@color/text_muted" android:textSize="10sp" />
                <TextView
                    android:id="@+id/commuteEtaValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XX min"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/commuteResultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a2e1a"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/commuteResultTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You'll make it"
                android:textColor="@color/accent_green"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/commuteResultSubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="X min to spare"
                android:textColor="#4a7a30"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>

